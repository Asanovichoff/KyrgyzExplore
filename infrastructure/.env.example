# ═══════════════════════════════════════════════════════════════
# KyrgyzExplore — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored.
# ═══════════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/kyrgyzexplore
DATABASE_USERNAME=kyrgyz
DATABASE_PASSWORD=kyrgyz_dev_pass

# ── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pass

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ── STRIPE ────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
# Platform commission (0.10 = 10%)
PLATFORM_FEE_PERCENT=0.10

# ── AWS S3 ────────────────────────────────────────────────────
# Create an IAM user with S3 permissions, get keys from AWS console
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_S3_BUCKET=kyrgyzexplore-media
AWS_REGION=eu-central-1
# CDN prefix for serving images (CloudFront or direct S3)
CDN_BASE_URL=https://kyrgyzexplore-media.s3.{AWS_REGION}.amazonaws.com

# ── FIREBASE ──────────────────────────────────────────────────
# Download service account JSON from Firebase console:
# Project Settings → Service accounts → Generate new private key
# Then base64-encode it: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_PROJECT_ID=kyrgyzexplore-XXXXX
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=REPLACE_WITH_BASE64_ENCODED_JSON

# ── SENDGRID ──────────────────────────────────────────────────
# Create API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.REPLACE
EMAIL_FROM_ADDRESS=noreply@kyrgyzexplore.com
EMAIL_FROM_NAME=KyrgyzExplore

# ── GOOGLE MAPS ───────────────────────────────────────────────
# Enable Maps SDK for Android + iOS in Google Cloud Console
# https://console.cloud.google.com/apis/library/maps-android-backend.googleapis.com
GOOGLE_MAPS_API_KEY=AIzaREPLACE

# ── APP ───────────────────────────────────────────────────────
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
APP_ENV=development
LOG_LEVEL=DEBUG

# ── LOCAL SMTP (MailHog) ──────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
